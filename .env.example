# Copy to .env for local dev. NEVER commit real secrets. Backend-only.
# nTZS — use TEST keys for all non-production work (ntzs_test_...).
NTZS_API_BASE=https://www.ntzs.co.tz/api/v1
NTZS_API_KEY=ntzs_test_xxxxxxxxxxxx
NTZS_WEBHOOK_SECRET=whsec_xxxxxxxxxxxx

# Treasury sub-wallet nTZS user ids — purpose-segregated firm funds. Issued by the nTZS partner
# setup (DISCOVERY_CHECKLIST item 3). Each MUST be a distinct wallet; no two purposes may share one.
NTZS_TREASURY_ESCROW=usr_xxxxxxxxxxxx
NTZS_TREASURY_SETTLEMENT=usr_xxxxxxxxxxxx
NTZS_TREASURY_RESERVES=usr_xxxxxxxxxxxx
NTZS_TREASURY_DISBURSEMENT=usr_xxxxxxxxxxxx
NTZS_TREASURY_FEES=usr_xxxxxxxxxxxx

# Postgres
DATABASE_URL=postgres://fimco:fimco@localhost:5432/fimco

# Redis
REDIS_URL=redis://localhost:6379

# Settlement cycle is a CONFIG value, not a constant (T+2 per brief, T+3 per DSE public rules — confirm).
SETTLEMENT_CYCLE_DAYS=2

# --- Frontend demo (Vercel) ---
# Shared password gate for the operator + portal demos. If unset, the gate is OFF (local dev).
DEMO_PASSWORD=change-me-shared-demo-password
# Demo URLs the landing page links to (set per Vercel project to the deployed URLs).
NEXT_PUBLIC_OPERATOR_URL=https://your-operator.vercel.app
NEXT_PUBLIC_PORTAL_URL=https://your-portal.vercel.app
