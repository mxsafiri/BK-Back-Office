{
  "//": "Whole-repo typecheck on source (no emit). Resolves @fimco/* to src via paths so no build is needed. Production builds use tsconfig.build.json (project references).",
  "extends": "./tsconfig.base.json",
  "compilerOptions": {
    "noEmit": true,
    "baseUrl": ".",
    "paths": {
      "@fimco/shared": ["packages/shared/src/index.ts"],
      "@fimco/core": ["packages/core/src/index.ts"],
      "@fimco/adapters": ["packages/adapters/src/index.ts"],
      "@fimco/api-client": ["packages/api-client/src/index.ts"]
    }
  },
  "include": ["packages/*/src/**/*.ts", "apps/*/src/**/*.ts"]
}
